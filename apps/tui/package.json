{
  "name": "@maria_rcks/t1code",
  "version": "0.0.5",
  "description": "Terminal-first T3 Code fork with an OpenTUI client",
  "homepage": "https://github.com/maria-rcks/t1code#readme",
  "bugs": {
    "url": "https://github.com/maria-rcks/t1code/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maria-rcks/t1code.git",
    "directory": "apps/tui"
  },
  "bin": {
    "t1code": "./bin/t1code.js"
  },
  "files": [
    "README.md",
    "bin",
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "dev:headless": "T3CODE_HEADLESS=1 bun run src/index.tsx",
    "build": "tsdown --config tsdown.config.ts && node scripts/bundle-server-dist.mjs",
    "prepack": "bun run build",
    "start": "bun dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@effect/platform-node": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/platform-node@8881a9b",
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "@pierre/diffs": "^1.1.0-beta.16",
    "effect": "https://pkg.pr.new/Effect-TS/effect-smol/effect@8881a9b",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "react-devtools-core": "^7.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@t3tools/client-core": "workspace:*",
    "@t3tools/contracts": "workspace:*",
    "@t3tools/shared": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "^19.0.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.9",
    "node": "^22.16 || ^23.11 || >=24.10"
  }
}
